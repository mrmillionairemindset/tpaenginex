# --------------------------------------------
# REQUIRED - Authentication (NextAuth.js)
# --------------------------------------------
NEXTAUTH_URL=https://wsnportal.com
NEXTAUTH_SECRET=nWz/3AqZhikYdnRXlCV+jEFDmCu0zxfzLeJ7fYmK3EQ=

# --------------------------------------------
# REQUIRED - Redis (BullMQ Queue System)
# ⚠️ ACTION REQUIRED: Update with Upstash URL
# --------------------------------------------
# Current value will NOT work in production!
# Get free Redis from: https://upstash.com/
# Example: rediss://default:YOUR_PASSWORD@your-instance.upstash.io:6379
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# REQUIRED - Storage (Supabase S3-Compatible)
# --------------------------------------------
STORAGE_BUCKET=rapidscreen-docs
STORAGE_ACCESS_KEY=004754ac97ba9a7fe65dd8c006aad5a8
STORAGE_SECRET_KEY=4c11af636c93a2b34f087e538b43c4e165a61ddca6692ae22924b325406a2cbe
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=https://hdkcpmntwzxbhvjtbbgi.supabase.co/storage/v1/s3

# --------------------------------------------
# OPTIONAL - Email (Resend)
# For sending email notifications
# Get API key from: https://resend.com/
# --------------------------------------------
RESEND_API_KEY=

# --------------------------------------------
# OPTIONAL - SMS (Twilio)
# For SMS notifications
# Get credentials from: https://www.twilio.com/
# --------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# --------------------------------------------
# OPTIONAL - Google Maps
# For site location and geocoding
# Get API key from: https://console.cloud.google.com/
# --------------------------------------------
MAPS_API_KEY=

# --------------------------------------------
# OPTIONAL - Google Sheets Integration
# For syncing orders to Google Sheets
# --------------------------------------------
SHEETS_SPREADSHEET_ID=
SHEETS_SERVICE_ACCOUNT_JSON=

# --------------------------------------------
# OPTIONAL - Monitoring (Sentry)
# For error tracking and monitoring
# Get credentials from: https://sentry.io/
# --------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ============================================
# DEPLOYMENT NOTES
# ============================================
# 1. After first deployment, update NEXTAUTH_URL to your Vercel URL
# 2. Once custom domain is configured, update both NEXTAUTH_URL and APP_BASE_URL
# 3. CRITICAL: Update REDIS_URL with Upstash before deployment
# 4. Optional variables can be added later as needed
# ============================================
