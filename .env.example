# Database
DATABASE_URL=postgres://user:password@host/dbname

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Authentication (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Storage (S3/R2/Supabase)
STORAGE_BUCKET=rapidscreen-docs
STORAGE_ACCESS_KEY=...
STORAGE_SECRET_KEY=...
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=https://...  # Optional: for R2/Supabase
STORAGE_PUBLIC_URL=https://...

# Email (SendGrid)
SENDGRID_API_KEY=SG....

# SMS (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_PHONE=+1...

# Maps (Google Maps)
MAPS_API_KEY=AIza...

# Google Sheets
SHEETS_SPREADSHEET_ID=...
SHEETS_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
SHEETS_WEBHOOK_SIGNING_SECRET=your-random-secret-here

# App Config
APP_BASE_URL=http://localhost:3000
NODE_ENV=development

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=https://...
SENTRY_ORG=...
SENTRY_PROJECT=...
