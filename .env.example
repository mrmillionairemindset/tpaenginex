# Database
DATABASE_URL=postgres://user:password@host/dbname

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Authentication (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Application-level encryption (AES-256-GCM for at-rest encryption of TOTP secrets, etc.)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# MUST be at least 32 chars. MUST NOT change once set (breaks existing ciphertexts).
APP_ENCRYPTION_KEY=your-32-char-minimum-encryption-key-here

# TOTP issuer shown in authenticator apps (optional, defaults to "TPAEngineX")
TOTP_ISSUER=TPAEngineX

# Error monitoring (Sentry). Leave unset to disable.
# NEXT_PUBLIC_SENTRY_DSN is safe to expose — it only permits error submission.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Logging level (trace | debug | info | warn | error | fatal). Defaults to info in prod, debug in dev.
LOG_LEVEL=info

# Base domain for multi-tenant subdomain routing (e.g., "tpaplatform.com")
BASE_DOMAIN=localhost:3000

# FMCSA National Registry submission for DOT driver physical exams
#   mock     - use local mock client (default in dev)
#   live     - submit to FMCSA_REGISTRY_URL with per-CME credentials
#   disabled - block submissions (returns auth error)
FMCSA_REGISTRY_MODE=mock
FMCSA_REGISTRY_URL=https://nationalregistry.fmcsa.dot.gov/api/v1

# Checkr background screening integration
#   mock     - local mock (default in dev)
#   live     - real Checkr API (credentials per-tenant in tenant_modules.config)
#   disabled - block submissions (returns auth error)
CHECKR_MODE=mock
CHECKR_BASE_URL=https://api.checkr.com/v1
# Dev-only: set this so mock webhooks validate. Never use in prod.
CHECKR_WEBHOOK_SECRET_DEV=dev-checkr-secret

# Storage (S3/R2/Supabase)
STORAGE_BUCKET=rapidscreen-docs
STORAGE_ACCESS_KEY=...
STORAGE_SECRET_KEY=...
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=https://...  # Optional: for R2/Supabase
STORAGE_PUBLIC_URL=https://...

# Email (SendGrid)
SENDGRID_API_KEY=SG....

# SMS (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_PHONE=+1...

# Maps (Google Maps)
MAPS_API_KEY=AIza...

# Google Sheets
SHEETS_SPREADSHEET_ID=...
SHEETS_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
SHEETS_WEBHOOK_SIGNING_SECRET=your-random-secret-here

# App Config
APP_BASE_URL=http://localhost:3000
NODE_ENV=development

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=https://...
SENTRY_ORG=...
SENTRY_PROJECT=...
