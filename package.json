    "@types/react-dom": "^18.3.0",
    "@types/ua-parser-js": "^0.7.39",
    "@vitest/ui": "^4.1.4",
    "drizzle-kit": "^0.24.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "happy-dom": "^20.9.0",
