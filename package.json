{
  "name": "tpaenginex",
  "version": "1.0.0",
  "description": "TPAEngineX - Multi-tenant SaaS platform for drug testing TPAs",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "docker:up": "docker compose up -d postgres redis mailpit",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d postgres redis mailpit",
    "docker:logs": "docker compose logs -f",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "worker": "tsx src/jobs/worker.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@auth/drizzle-adapter": "^1.11.0",
    "@aws-sdk/client-s3": "^3.914.0",
