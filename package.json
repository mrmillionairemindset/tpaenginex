    "otpauth": "^9.5.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.15.2",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "postcss": "^8.5.6",
    "postgres": "^3.4.4",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.6.0",
